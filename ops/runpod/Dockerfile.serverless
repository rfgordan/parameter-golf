FROM runpod/parameter-golf:latest

WORKDIR /workspace/parameter-golf

# The base image is expected to contain the challenge runtime; this only adds the
# Serverless handler dependency.
RUN python3 -m pip install --no-cache-dir runpod

COPY . /workspace/parameter-golf

ENV PYTHONUNBUFFERED=1

CMD ["python3", "/workspace/parameter-golf/ops/runpod/serverless_handler.py"]
